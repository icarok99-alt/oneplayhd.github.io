<?xml version="1.0" encoding="UTF-8"?>
<addon id="plugin.video.onevip" 
       version="1.0.5" 
	   name="ONEPLAY VIP BETA" 
	   provider-name="OnePlay">
    <requires>
        <import addon="script.module.simplejson" />
        <import addon="script.module.six" />
        <import addon="script.module.kodi-six" />
        <import addon="script.module.requests"/>
        <import addon="script.module.pyxbmct" />
    </requires>    
    <extension point="xbmc.python.pluginsource" library="app.py">
        <provides>video</provides>
    </extension>  
    <extension point="xbmc.addon.metadata">
		<summary lang="pt">OnePlay VIP é um plugin baseado no aplicativo OnePlay Alpha para dispositivos TV BOX ou PC e Notebook.</summary>
		<description lang="pt">Essa é uma versão semelhante ao OnePlay Alpha com algumas diferenças até porque se trata e um addon para o KODI.</description>
        <description></description>
        <platform>all</platform>
        <assets>
			<icon>icon.png</icon>
            <fanart>fanart.jpg</fanart>
            <screenshot>resources/media/screenshot-1.jpg</screenshot>
            <screenshot>resources/media/screenshot-2.jpg</screenshot>
            <screenshot>resources/media/screenshot-3.jpg</screenshot>
		</assets>
    </extension>
</addon>